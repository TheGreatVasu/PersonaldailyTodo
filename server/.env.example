PORT=3001
# Comma-separated origins allowed to call the API (your frontend URL)
# Example: http://localhost:5173,https://your-app.vercel.app
# You can also use wildcard entries, e.g. https://*.vercel.app
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
# MongoDB Atlas connection string
MONGODB_URI=
# Optional database name (default: daily_todo)
MONGODB_DB=daily_todo

# JWT secret used to sign auth tokens
JWT_SECRET=change-me-in-production
# Token lifetime (e.g. 7d, 1h)
JWT_EXPIRES_IN=7d
